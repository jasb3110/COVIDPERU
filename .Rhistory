rep(NA,length(Dates)),#2
rep(NA,length(Dates)),#3
rep(NA,length(Dates)),#4
rep(NA,length(Dates)),#5
rep(NA,length(Dates)),#6
rep(NA,length(Dates)),#7
rep(NA,length(Dates)),#8
rep(NA,length(Dates)),#9
rep(NA,length(Dates)),#10
