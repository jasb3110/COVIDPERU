datos$`Vacunados 1ra`[1:length(vacunados$X1ra)]=vacunados$X1ra
datos$`Vacunados 2da`[1:length(vacunados$X2da)]=vacunados$X2da
datos$`Vacunados 3ra`[1:length(vacunados$X3ra)]=vacunados$X3ra
